# Tastytrade credentials (your regular login)
TT_USERNAME=your_username
TT_PASSWORD=your_password

# Use sandbox for testing (set to false for real money)
TT_SANDBOX=true

# Bot settings
DRY_RUN=true
POSITION_SIZE_USD=50
MAX_OPEN_POSITIONS=3
POLL_INTERVAL_SECONDS=30

# Strategy settings
TARGET_DELTA=10
SPREAD_WIDTH=1
PROFIT_TARGET_PCT=50
STOP_LOSS_MULTIPLIER=2
ENTRY_AFTER_MINUTES=60
