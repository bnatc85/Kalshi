# ─── KALSHI ───────────────────────────────────────────────────────────────────
# Get these from: kalshi.com → Settings → API
KALSHI_API_KEY=your_api_key_id_here

# Paste your full RSA private key (from the .pem file Kalshi gives you)
# Keep the newlines — wrap in quotes if your shell requires it
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
PASTE_YOUR_KEY_HERE
-----END RSA PRIVATE KEY-----"

# ─── POLYMARKET (optional — needed for cross-platform arb) ────────────────────
# Your Polygon wallet private key (0x...)
POLYMARKET_PRIVATE_KEY=
# Optional: proxy wallet address if using Gnosis Safe
POLYMARKET_PROXY_ADDRESS=

# ─── BOT CONFIG ───────────────────────────────────────────────────────────────
DRY_RUN=true
MIN_SPREAD_BPS=150
MIN_IRR=20
POSITION_SIZE_USD=100
MAX_OPEN_POSITIONS=3
POLL_INTERVAL_SECONDS=30
